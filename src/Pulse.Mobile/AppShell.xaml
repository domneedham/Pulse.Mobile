<?xml version="1.0" encoding="UTF-8" ?>
<nalu:NaluShell
    x:Class="Pulse.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:nalu="https://nalu-development.github.com/nalu/navigation"
    xmlns:onboarding="clr-namespace:Pulse.Views.Onboarding"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:views="clr-namespace:Pulse.Views"
    FlyoutBackgroundColor="{DynamicResource PageBackground}"
    FlyoutHeaderBehavior="Fixed">

    <Shell.FlyoutHeader>
        <controls:FlyoutHeaderView x:Name="TheFlyoutHeader" />
    </Shell.FlyoutHeader>

    <Shell.FlyoutContent>
        <!--  Only lists what's actually built (Profile & settings). Calendar, Date nights, Wishlist,
              Present ideas, and Couple goals join here once those screens exist.  -->
        <VerticalStackLayout Padding="8,4,8,0" Spacing="2">
            <Label Margin="12,10,0,4" Style="{StaticResource SectionLabel}" Text="You" />
            <controls:FlyoutMenuRow Command="{Binding Source={x:Reference TheFlyoutHeader}, Path=OpenProfileCommand}" Icon="Profile" Text="Profile &amp; settings" />
        </VerticalStackLayout>
    </Shell.FlyoutContent>

    <!--  Tab-less roots: splash, signed-out, and pre-connection pairing. FlyoutBehavior=Disabled so the
          hamburger/swipe gesture never appears before there's a flyout worth showing.  -->
    <ShellContent nalu:Navigation.PageType="views:StartupView" Shell.FlyoutBehavior="Disabled" />

    <ShellContent nalu:Navigation.PageType="onboarding:SignUpView" Shell.FlyoutBehavior="Disabled" />

    <ShellContent nalu:Navigation.PageType="onboarding:SignInView" Shell.FlyoutBehavior="Disabled" />

    <ShellContent nalu:Navigation.PageType="views:ConnectView" Shell.FlyoutBehavior="Disabled" />

    <!--  Signed-in + connected experience: no tab bar. Trail is the single home page — today's Moment
          sits pinned at the top, history scrolls below.  -->
    <ShellContent Shell.FlyoutBehavior="Flyout" nalu:Navigation.PageType="views:TrailView" />

</nalu:NaluShell>
