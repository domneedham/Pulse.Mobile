<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    x:Class="Pulse.Resources.Themes.DarkTheme"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        DARK THEME — mirrors every key in LightTheme.xaml.
        Surfaces go deep navy-black; Ink flips light so it stays readable.
    -->

    <!--  Brand  -->
    <Color x:Key="Brand">#FF8C8C</Color>
    <Color x:Key="BrandDark">#FF7A7A</Color>
    <Color x:Key="BrandSoft">#3A1E1E</Color>
    <Color x:Key="OnBrand">#1A0B0B</Color>

    <Color x:Key="Accent">#B7A2F0</Color>
    <Color x:Key="AccentSoft">#241F3A</Color>

    <!--  Navy  -->
    <Color x:Key="Navy">#0A1A45</Color>
    <Color x:Key="NavyAlt">#0E2566</Color>

    <!--  Surfaces  -->
    <Color x:Key="PageBackground">#070C1A</Color>
    <Color x:Key="Surface">#101830</Color>
    <Color x:Key="SurfaceAlt">#18223E</Color>
    <Color x:Key="Stroke">#27314F</Color>

    <!--  Text  -->
    <Color x:Key="Ink">#EEF1F8</Color>
    <Color x:Key="InkMid">#A6AEC2</Color>
    <Color x:Key="InkLight">#6B7591</Color>

    <!--  Contrast block  -->
    <Color x:Key="Contrast">#EEF1F8</Color>
    <Color x:Key="OnContrast">#07153D</Color>

    <!--  Status  -->
    <Color x:Key="Success">#7FAE8A</Color>
    <Color x:Key="Danger">#E06058</Color>
    <Color x:Key="DangerLight">#3A201E</Color>

</ResourceDictionary>
