<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    x:Class="Pulse.Resources.Themes.LightTheme"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        LIGHT THEME — Pulse's default.
        Palette from the product brief: deep navy, coral primary, purple accent, warm background.
        Keys here are mirrored exactly in DarkTheme.xaml so the app can swap at runtime via DynamicResource.
    -->

    <!--  Brand: coral is the primary action colour; purple is the secondary accent (PulseTouch).  -->
    <Color x:Key="Brand">#FF7A7A</Color>
    <Color x:Key="BrandDark">#F25F5F</Color>
    <Color x:Key="BrandSoft">#FFE4E4</Color>
    <Color x:Key="OnBrand">#FFFFFF</Color>

    <Color x:Key="Accent">#A98BFF</Color>
    <Color x:Key="AccentSoft">#ECE5FF</Color>

    <!--  Navy — branding, dark surfaces, the connection nodes.  -->
    <Color x:Key="Navy">#07153D</Color>
    <Color x:Key="NavyAlt">#0B1F5A</Color>

    <!--  Surfaces  -->
    <Color x:Key="PageBackground">#FAF8F5</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceAlt">#F1EEE9</Color>
    <Color x:Key="Stroke">#E5E0D8</Color>

    <!--  Text  -->
    <Color x:Key="Ink">#07153D</Color>
    <Color x:Key="InkMid">#5B6478</Color>
    <Color x:Key="InkLight">#9AA1B0</Color>

    <!--  Contrast block (navy chips / dark buttons)  -->
    <Color x:Key="Contrast">#07153D</Color>
    <Color x:Key="OnContrast">#FFFFFF</Color>

    <!--  Status  -->
    <Color x:Key="Success">#7FAE8A</Color>
    <Color x:Key="Danger">#D03A30</Color>
    <Color x:Key="DangerLight">#FBEAE8</Color>

</ResourceDictionary>
