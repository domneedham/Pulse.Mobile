<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:nalu="https://nalu-development.github.com/nalu/layouts">

    <Style TargetType="nalu:PopupScrim">
        <Setter Property="Background" Value="#80000000" />
    </Style>

    <Style TargetType="nalu:PopupContainer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="VerticalOptions" Value="End" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!--
        TYPE SCALE
        Font families are aliases registered in MauiProgram (Sans* = Nunito,
        Serif* = Noto Serif) so the actual typeface can be swapped in one place.
    -->

    <!--  Big screen titles: "My Challenges", "Invite friends"  -->
    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="SansExtraBold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
    </Style>

    <!--  Hero display: challenge names ("SUMMER FITNESS") — heavy italic, uppercase  -->
    <Style x:Key="DisplayTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="SansBoldItalic" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="TextTransform" Value="Uppercase" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
        <Setter Property="LineHeight" Value="0.95" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
    </Style>

    <Style
        x:Key="DisplayTitleSmall"
        BasedOn="{StaticResource DisplayTitle}"
        TargetType="Label">
        <Setter Property="FontSize" Value="22" />
    </Style>

    <!--  Card headline: "Dom overtook Mike"  -->
    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
    </Style>

    <!--  Section headers / eyebrows: "SCORING RULES", "POSITION CHANGE"  -->
    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{DynamicResource InkLight}" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="TextTransform" Value="Uppercase" />
    </Style>

    <!--  Big numbers: points, ranks  -->
    <Style x:Key="StatValue" TargetType="Label">
        <Setter Property="FontFamily" Value="SansExtraBold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
    </Style>

    <Style
        x:Key="StatValueLarge"
        BasedOn="{StaticResource StatValue}"
        TargetType="Label">
        <Setter Property="FontSize" Value="30" />
    </Style>

    <Style x:Key="BodyLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource InkMid}" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{DynamicResource InkMid}" />
    </Style>

    <Style x:Key="BodySmall" TargetType="Label">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource InkLight}" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontFamily" Value="SansMedium" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextColor" Value="{DynamicResource InkLight}" />
        <Setter Property="CharacterSpacing" Value="0.5" />
    </Style>

    <!--  Default label  -->
    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{DynamicResource InkMid}" />
    </Style>

    <!--  SURFACES  -->

    <!--  Standard white card — hairline border + a whisper of elevation, per the mockups  -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="{DynamicResource Stroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Shadow">
            <Shadow
                Brush="{DynamicResource Ink}"
                Opacity="0.05"
                Radius="14"
                Offset="0,4" />
        </Setter>
    </Style>

    <!--  Hero / challenge card — bigger radius, tint applied per item  -->
    <Style x:Key="CardLarge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Shadow">
            <Shadow
                Brush="{DynamicResource Ink}"
                Opacity="0.06"
                Radius="18"
                Offset="0,6" />
        </Setter>
    </Style>

    <!--  Outlined selectable tile (theme/trophy pickers)  -->
    <Style x:Key="SelectableTile" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="{DynamicResource Stroke}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!--  Pill chip (stat chips, toggles)  -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 100" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <!--  Round icon badge (feed cards, scoring rules)  -->
    <Style x:Key="IconBadge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 100" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <!--  Segmented control track (Purchase / History, History / Rewards toggles)  -->
    <Style x:Key="SegmentTrack" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 100" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <!--  A single segment within a SegmentTrack. Selected state filled via DataTrigger in the view.  -->
    <Style x:Key="SegmentTab" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 100" />
        <Setter Property="Padding" Value="0,9" />
    </Style>

    <!--  Hairline divider between stacked rows inside a Card (link lists, participants, scoring)  -->
    <Style x:Key="RowDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Color" Value="{DynamicResource Stroke}" />
    </Style>

    <Style x:Key="DragHandle" TargetType="BoxView">
        <Setter Property="Margin" Value="0,8,0,8" />
        <Setter Property="HeightRequest" Value="4" />
        <Setter Property="WidthRequest" Value="40" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Color" Value="{DynamicResource Stroke}" />
    </Style>

    <!--  BUTTONS  -->

    <!--  Default: brand-orange primary  -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource OnBrand}" />
        <Setter Property="Background" Value="{DynamicResource Brand}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="HeightRequest" Value="54" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{DynamicResource Brand}" />
                            <Setter Property="TextColor" Value="{DynamicResource OnBrand}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{DynamicResource BrandDark}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
                            <Setter Property="TextColor" Value="{DynamicResource InkLight}" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!--  Quiet secondary: white surface, ink text  -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="BorderColor" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="HeightRequest" Value="54" />
    </Style>

    <!--  Text-only button  -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{DynamicResource InkMid}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="FontFamily" Value="SansBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource Danger}" />
        <Setter Property="Background" Value="{DynamicResource DangerLight}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="HeightRequest" Value="54" />
    </Style>

    <!--  Round 44pt icon button (back arrows, header actions) — set Text to an mdi glyph  -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="FontFamily" Value="mdi" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style
        x:Key="IconButtonGhost"
        BasedOn="{StaticResource IconButton}"
        TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource InkMid}" />
    </Style>

    <!--  INPUTS  -->

    <Style TargetType="Entry">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource InkLight}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <!--  Bordered wrapper to put an Entry inside  -->
    <Style x:Key="InputField" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Surface}" />
        <Setter Property="Stroke" Value="{DynamicResource Stroke}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="16,2" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="FontFamily" Value="SansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{DynamicResource Ink}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource InkLight}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource Brand}" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{DynamicResource Brand}" />
    </Style>

    <!--  CHROME  -->

    <Style ApplyToDerivedTypes="True" TargetType="Page">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource PageBackground}" />
    </Style>

    <Style ApplyToDerivedTypes="True" TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource PageBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource Ink}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource Ink}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Brand}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{DynamicResource Brand}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource InkLight}" />
    </Style>

</ResourceDictionary>
