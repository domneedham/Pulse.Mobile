<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.TrailView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    Title="Your Trail"
    x:DataType="vm:TrailViewModel"
    SafeAreaEdges="None">

    <Grid Padding="20,8,20,0" SafeAreaEdges="None">

        <RefreshView
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}"
            SafeAreaEdges="None">
            <Grid SafeAreaEdges="None">

                <CollectionView
                    IsGrouped="True"
                    ItemsSource="{Binding Groups}"
                    SelectionMode="None">

                    <!--  Date label on the timeline spine  -->
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="vm:TrailGroup">
                            <Grid Padding="0,14,0,4" ColumnDefinitions="44,*">
                                <Label
                                    Grid.Column="1"
                                    Style="{StaticResource SectionLabel}"
                                    Text="{Binding Title}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TrailRowVm">
                            <Grid ColumnDefinitions="44,*" RowDefinitions="*">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrailViewModel}}, Path=OpenItemCommand}" CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <!--  Spine: continuous vertical line + node dot centered on the row  -->
                                <Grid Grid.Column="0">
                                    <BoxView
                                        Background="{DynamicResource Stroke}"
                                        HorizontalOptions="Center"
                                        WidthRequest="2" />
                                    <!--  Outer ring  -->
                                    <Border
                                        Background="{DynamicResource PageBackground}"
                                        HeightRequest="22"
                                        HorizontalOptions="Center"
                                        StrokeShape="RoundRectangle 11"
                                        StrokeThickness="0"
                                        VerticalOptions="Center"
                                        WidthRequest="22">
                                        <!--  Inner dot: moments = accent (purple); pulses = sender's person colour  -->
                                        <Border
                                            Background="{Binding NodeColor}"
                                            HeightRequest="13"
                                            HorizontalOptions="Center"
                                            StrokeShape="RoundRectangle 6.5"
                                            StrokeThickness="0"
                                            VerticalOptions="Center"
                                            WidthRequest="13" />
                                    </Border>
                                </Grid>

                                <!--  Content  -->
                                <Grid Grid.Column="1" Padding="6,8,0,8">

                                    <!--  Pulse row — a plain card: avatar + "You"/name + category on top,
                                          timestamp trailing; body is either the phrase text or, for a
                                          Touch pulse, the stroke drawing rendered inline.  -->
                                    <Border Padding="12" IsVisible="{Binding IsPulse}" Style="{StaticResource Card}">
                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                                <controls:AvatarView
                                                    Grid.Column="0"
                                                    AvatarUrl="{Binding PersonAvatarUrl}"
                                                    DisplayName="{Binding PersonName}"
                                                    Size="26" />
                                                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                                    <Label FontFamily="SansBold" FontSize="14" Text="{Binding PersonLabel}" TextColor="{DynamicResource Ink}" />
                                                    <Label FontSize="13" Style="{StaticResource Caption}" Text="{Binding CategoryLabel}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                                <controls:AppIcon
                                                    Grid.Column="2"
                                                    Icon="Star"
                                                    IsVisible="{Binding IsFavorite}"
                                                    Size="14"
                                                    VerticalOptions="Center"
                                                    Color="{DynamicResource Accent}" />
                                                <Label Grid.Column="3" Style="{StaticResource Caption}" Text="{Binding When}" VerticalOptions="Center" />
                                            </Grid>

                                            <!--  Drawing pulse: the stroke playback IS the content.  -->
                                            <Border
                                                Padding="8"
                                                Background="{DynamicResource PageBackground}"
                                                HeightRequest="120"
                                                IsVisible="{Binding IsPulseDrawing}"
                                                Stroke="{DynamicResource Stroke}"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="1">
                                                <controls:StrokeView StrokeData="{Binding StrokeData}" />
                                            </Border>

                                            <!--  Phrase pulse: text (+ optional note).  -->
                                            <VerticalStackLayout IsVisible="{Binding IsPulseDrawing, Converter={StaticResource InvertedBoolConverter}}" Spacing="2">
                                                <Label Style="{StaticResource BodyMedium}" Text="{Binding Text}" />
                                                <Label
                                                    IsVisible="{Binding HasNote}"
                                                    LineBreakMode="TailTruncation"
                                                    MaxLines="2"
                                                    Style="{StaticResource BodySmall}"
                                                    Text="{Binding Note}" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>

                                    <!--  Moment card — the same big card for every moment regardless of
                                          day: category pill + action label, title + prompt + thumbnail
                                          stack, two-avatar progress row, and (only while unanswered by
                                          me) a Start button. Today's incomplete moment just naturally
                                          sorts to the top of the "Today" group; once answered it's the
                                          same card, minus the button, moving down the trail like any
                                          other day.  -->
                                    <Border Padding="18" IsVisible="{Binding IsMoment}" Style="{StaticResource Card}">
                                        <VerticalStackLayout Spacing="16">

                                            <Grid ColumnDefinitions="*,Auto">
                                                <Border
                                                    Grid.Column="0"
                                                    Padding="10,5"
                                                    Background="{DynamicResource AccentSoft}"
                                                    HorizontalOptions="Start"
                                                    StrokeShape="RoundRectangle 8"
                                                    StrokeThickness="0">
                                                    <HorizontalStackLayout Spacing="6">
                                                        <controls:AppIcon
                                                            Icon="{Binding Icon}"
                                                            Size="14"
                                                            VerticalOptions="Center"
                                                            Color="{DynamicResource Accent}" />
                                                        <Label
                                                            FontFamily="SansSemiBold"
                                                            FontSize="12"
                                                            Text="{Binding CategoryLabel}"
                                                            TextColor="{DynamicResource Accent}"
                                                            VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                </Border>
                                                <Label
                                                    Grid.Column="1"
                                                    FontFamily="SansBold"
                                                    FontSize="11"
                                                    IsVisible="{Binding CanRespond}"
                                                    Text="{Binding ActionLabel}"
                                                    TextColor="{DynamicResource Accent}"
                                                    VerticalOptions="Center" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <VerticalStackLayout
                                                    Grid.Column="0"
                                                    Spacing="6"
                                                    VerticalOptions="Center">
                                                    <Label
                                                        FontFamily="SansExtraBold"
                                                        FontSize="26"
                                                        Text="{Binding Text}"
                                                        TextColor="{DynamicResource Ink}" />
                                                    <Label Style="{StaticResource BodyMedium}" Text="{Binding Prompt}" />
                                                </VerticalStackLayout>
                                                <Grid
                                                    Grid.Column="1"
                                                    HeightRequest="88"
                                                    VerticalOptions="Center"
                                                    WidthRequest="100">
                                                    <controls:MomentThumbnailView
                                                        HeightRequest="80"
                                                        HorizontalOptions="Start"
                                                        PersonName="{Binding PartnerName}"
                                                        PhotoUrl="{Binding PartnerPhotoUrl}"
                                                        Rotation="-12"
                                                        StrokeData="{Binding PartnerStrokeData}"
                                                        WidthRequest="64"
                                                        ZIndex="0" />
                                                    <controls:MomentThumbnailView
                                                        HeightRequest="80"
                                                        HorizontalOptions="End"
                                                        PersonName="{Binding MyName}"
                                                        PhotoUrl="{Binding MyPhotoUrl}"
                                                        Rotation="12"
                                                        StrokeData="{Binding MyStrokeData}"
                                                        WidthRequest="64"
                                                        ZIndex="1" />
                                                </Grid>
                                            </Grid>

                                            <!--  Two-avatar progress row  -->
                                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                    <Grid>
                                                        <controls:AvatarView
                                                            AvatarUrl="{Binding MyAvatarUrl}"
                                                            DisplayName="{Binding MyName}"
                                                            Size="38" />
                                                        <Border
                                                            Background="{DynamicResource Brand}"
                                                            HeightRequest="16"
                                                            HorizontalOptions="End"
                                                            IsVisible="{Binding MyDone}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            VerticalOptions="End"
                                                            WidthRequest="16">
                                                            <controls:AppIcon
                                                                HorizontalOptions="Center"
                                                                Icon="Check"
                                                                Size="10"
                                                                VerticalOptions="Center"
                                                                Color="White" />
                                                        </Border>
                                                    </Grid>
                                                    <Label
                                                        FontSize="11"
                                                        HorizontalOptions="Center"
                                                        Style="{StaticResource Caption}"
                                                        Text="{Binding MyName}" />
                                                </VerticalStackLayout>

                                                <BoxView
                                                    Grid.Column="1"
                                                    Margin="10,0"
                                                    Background="{DynamicResource Stroke}"
                                                    HeightRequest="2"
                                                    VerticalOptions="Center" />

                                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                                    <Grid>
                                                        <controls:AvatarView
                                                            AvatarUrl="{Binding PartnerAvatarUrl}"
                                                            DisplayName="{Binding PartnerName}"
                                                            Size="38" />
                                                        <Border
                                                            Background="{DynamicResource Brand}"
                                                            HeightRequest="16"
                                                            HorizontalOptions="End"
                                                            IsVisible="{Binding PartnerDone}"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            VerticalOptions="End"
                                                            WidthRequest="16">
                                                            <controls:AppIcon
                                                                HorizontalOptions="Center"
                                                                Icon="Check"
                                                                Size="10"
                                                                VerticalOptions="Center"
                                                                Color="White" />
                                                        </Border>
                                                    </Grid>
                                                    <Label
                                                        FontSize="11"
                                                        HorizontalOptions="Center"
                                                        Style="{StaticResource Caption}"
                                                        Text="{Binding PartnerName}" />
                                                </VerticalStackLayout>
                                            </Grid>

                                            <Button
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrailViewModel}}, Path=OpenItemCommand}"
                                                CommandParameter="{Binding .}"
                                                IsVisible="{Binding CanRespond}"
                                                Text="Start Moment" />

                                        </VerticalStackLayout>
                                    </Border>

                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <Grid Padding="0,24,0,32" ColumnDefinitions="44,*">
                            <BoxView
                                Grid.Column="0"
                                Background="{DynamicResource Stroke}"
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Start"
                                WidthRequest="2" />
                            <Label
                                Grid.Column="1"
                                Style="{StaticResource Caption}"
                                Text="The beginning of your trail."
                                VerticalOptions="Center" />
                        </Grid>
                    </CollectionView.Footer>
                </CollectionView>

                <!--  Empty state  -->
                <VerticalStackLayout
                    IsVisible="{Binding IsEmpty}"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Border
                        Background="{DynamicResource AccentSoft}"
                        HeightRequest="96"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 48"
                        StrokeThickness="0"
                        WidthRequest="96">
                        <controls:AppIcon
                            HorizontalOptions="Center"
                            Icon="Trail"
                            Size="44"
                            VerticalOptions="Center"
                            Color="{DynamicResource Accent}" />
                    </Border>
                    <Label
                        FontFamily="SansBold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="Your trail starts here"
                        TextColor="{DynamicResource Ink}" />
                    <Label
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource BodySmall}"
                        Text="Send a pulse or complete today's Moment to begin your story together." />
                </VerticalStackLayout>

            </Grid>
        </RefreshView>

        <controls:ComposeButton />

    </Grid>


</ContentPage>
