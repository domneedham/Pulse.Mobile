<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.TrailView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:TrailViewModel"
    Title="Your Trail">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding OpenMomentsCommand}" Order="Primary" Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="mdi" Glyph="{x:Static resources:MdiIcons.CalendarHeartOutline}" Color="{DynamicResource Brand}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid Padding="20,8,20,0">

        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <Grid>

                <CollectionView
                    IsGrouped="True"
                    ItemsSource="{Binding Groups}"
                    SelectionMode="None">

                    <!--  Date label on the timeline spine  -->
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="vm:TrailGroup">
                            <Grid Padding="0,14,0,4" ColumnDefinitions="44,*">
                                <Label
                                    Grid.Column="1"
                                    Style="{StaticResource SectionLabel}"
                                    Text="{Binding Title}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TrailRowVm">
                            <Grid ColumnDefinitions="44,*" RowDefinitions="*">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrailViewModel}}, Path=OpenItemCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <!--  Spine: continuous vertical line + node dot centered on the row  -->
                                <Grid Grid.Column="0">
                                    <BoxView
                                        Background="{DynamicResource Stroke}"
                                        HorizontalOptions="Center"
                                        WidthRequest="2" />
                                    <!--  Outer ring  -->
                                    <Border
                                        Background="{DynamicResource PageBackground}"
                                        HeightRequest="22"
                                        HorizontalOptions="Center"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 11"
                                        VerticalOptions="Center"
                                        WidthRequest="22">
                                        <!--  Inner dot: moments = accent (purple); pulses = sender's person colour  -->
                                        <Border
                                            Background="{Binding NodeColor}"
                                            HeightRequest="13"
                                            HorizontalOptions="Center"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 6.5"
                                            VerticalOptions="Center"
                                            WidthRequest="13" />
                                    </Border>
                                </Grid>

                                <!--  Content  -->
                                <Grid Grid.Column="1" Padding="6,8,0,8">

                                    <!--  Pulse row  -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" IsVisible="{Binding IsPulse}">
                                        <Border Grid.Column="0" Background="{Binding BadgeTint}" HeightRequest="38" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Center" WidthRequest="38">
                                            <controls:AppIcon Color="{Binding NodeColor}" Icon="{Binding Icon}" Size="19" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Style="{StaticResource BodyMedium}" Text="{Binding Text}" />
                                            <Label IsVisible="{Binding HasNote}" LineBreakMode="TailTruncation" MaxLines="1" Style="{StaticResource BodySmall}" Text="{Binding Note}" />
                                            <Label Style="{StaticResource Caption}" Text="{Binding When}" />
                                        </VerticalStackLayout>
                                        <controls:AppIcon Grid.Column="2" Color="{DynamicResource Accent}" Icon="Star" IsVisible="{Binding IsFavorite}" Size="15" VerticalOptions="Center" />
                                    </Grid>

                                    <!--  Moment card  -->
                                    <Border
                                        Padding="12"
                                        Background="{DynamicResource AccentSoft}"
                                        IsVisible="{Binding IsMoment}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 16"
                                        StrokeThickness="0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0" Background="{DynamicResource Surface}" HeightRequest="40" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Center" WidthRequest="40">
                                                <controls:AppIcon Color="{DynamicResource Accent}" Icon="{Binding Icon}" Size="20" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label FontFamily="SansBold" FontSize="15" Text="{Binding Text}" TextColor="{DynamicResource Ink}" />
                                                <Label Style="{StaticResource Caption}" Text="{Binding CategoryLabel}" />
                                                <HorizontalStackLayout Spacing="5">
                                                    <controls:AppIcon Color="{DynamicResource Brand}" Icon="Heart" IsVisible="{Binding MomentComplete}" Size="12" VerticalOptions="Center" />
                                                    <Label FontFamily="SansSemiBold" FontSize="11" Text="{Binding MomentStatus}" TextColor="{DynamicResource Brand}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!--  Thumbnail (completed photo / drawing)  -->
                                            <Border
                                                Grid.Column="2"
                                                HeightRequest="48"
                                                IsVisible="{Binding HasThumbnail}"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0"
                                                VerticalOptions="Center"
                                                WidthRequest="48">
                                                <Grid>
                                                    <Image Aspect="AspectFill" IsVisible="{Binding HasPhoto}" Source="{Binding PhotoUrl}" />
                                                    <controls:StrokeView IsVisible="{Binding HasDrawing}" StrokeData="{Binding StrokeData}" />
                                                </Grid>
                                            </Border>
                                            <controls:AppIcon Grid.Column="2" Color="{DynamicResource InkLight}" Icon="ChevronRight" IsVisible="{Binding HasThumbnail, Converter={StaticResource InvertedBoolConverter}}" Size="20" VerticalOptions="Center" />
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.Footer>
                        <Grid Padding="0,24,0,32" ColumnDefinitions="44,*">
                            <BoxView Grid.Column="0" Background="{DynamicResource Stroke}" HeightRequest="20" HorizontalOptions="Center" VerticalOptions="Start" WidthRequest="2" />
                            <Label Grid.Column="1" Style="{StaticResource Caption}" Text="The beginning of your trail." VerticalOptions="Center" />
                        </Grid>
                    </CollectionView.Footer>
                </CollectionView>

                <!--  Empty state  -->
                <VerticalStackLayout
                    IsVisible="{Binding IsEmpty}"
                    Spacing="12"
                    VerticalOptions="Center">
                    <Border
                        Background="{DynamicResource AccentSoft}"
                        HeightRequest="96"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 48"
                        StrokeThickness="0"
                        WidthRequest="96">
                        <controls:AppIcon Color="{DynamicResource Accent}" HorizontalOptions="Center" Icon="Trail" Size="44" VerticalOptions="Center" />
                    </Border>
                    <Label FontFamily="SansBold" FontSize="20" HorizontalOptions="Center" Text="Your trail starts here" TextColor="{DynamicResource Ink}" />
                    <Label HorizontalOptions="Center" HorizontalTextAlignment="Center" Style="{StaticResource BodySmall}" Text="Send a pulse or complete today's Moment to begin your story together." />
                </VerticalStackLayout>

            </Grid>
        </RefreshView>

    </Grid>

</ContentPage>
