<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.HelpSupportView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:ui="clr-namespace:Pulse.UI.Controls"
    xmlns:views="clr-namespace:Pulse.Views"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:HelpSupportViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid Padding="16,8,16,0" RowDefinitions="Auto,*">

        <views:SubPageHeader Title="Help &amp; support" Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,8,0,40" Spacing="16">

                <Border Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="0">

                        <!--  Report a problem  -->
                        <Grid
                            Padding="0,12"
                            ColumnDefinitions="40,*,Auto"
                            ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ReportProblemCommand}" />
                            </Grid.GestureRecognizers>
                            <Border
                                Grid.Column="0"
                                ui:Tint.Background="ActMove"
                                Style="{StaticResource IconBadge}">
                                <Label
                                    ui:Tint.Foreground="ActMove"
                                    FontFamily="mdi"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="{x:Static resources:MdiIcons.BugOutline}"
                                    VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Style="{StaticResource CardTitle}" Text="Report a problem" />
                                <Label Style="{StaticResource BodySmall}" Text="Sends app logs so we can help" />
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                FontFamily="mdi"
                                FontSize="20"
                                Text="{x:Static resources:MdiIcons.ChevronRight}"
                                TextColor="{DynamicResource InkLight}"
                                VerticalOptions="Center" />
                        </Grid>

                        <BoxView Style="{StaticResource RowDivider}" />

                        <!--  Request a feature  -->
                        <Grid
                            Padding="0,12"
                            ColumnDefinitions="40,*,Auto"
                            ColumnSpacing="14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RequestFeatureCommand}" />
                            </Grid.GestureRecognizers>
                            <Border
                                Grid.Column="0"
                                ui:Tint.Background="ActMind"
                                Style="{StaticResource IconBadge}">
                                <Label
                                    ui:Tint.Foreground="ActMind"
                                    FontFamily="mdi"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="{x:Static resources:MdiIcons.LightbulbOnOutline}"
                                    VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Style="{StaticResource CardTitle}" Text="Request a feature" />
                                <Label Style="{StaticResource BodySmall}" Text="Tell us what you'd like to see" />
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                FontFamily="mdi"
                                FontSize="20"
                                Text="{x:Static resources:MdiIcons.ChevronRight}"
                                TextColor="{DynamicResource InkLight}"
                                VerticalOptions="Center" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
