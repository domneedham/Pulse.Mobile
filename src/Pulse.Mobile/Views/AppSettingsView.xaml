<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.AppSettingsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pulse.Views"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:AppSettingsViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid Padding="16,8,16,0" RowDefinitions="Auto,*">

        <views:SubPageHeader Title="App settings" Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,8,0,40" Spacing="12">

                <!--  Appearance  -->
                <Label Style="{StaticResource SectionLabel}" Text="Appearance" />
                <HorizontalStackLayout BindableLayout.ItemsSource="{Binding ThemeOptions}" Spacing="8">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ThemeOption">
                            <Border Style="{StaticResource Chip}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectThemeCommand, Source={RelativeSource AncestorType={x:Type vm:AppSettingsViewModel}}, x:DataType=vm:AppSettingsViewModel}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger
                                        Binding="{Binding IsSelected}"
                                        TargetType="Border"
                                        Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Contrast}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Style="{StaticResource BodyMedium}" Text="{Binding Label}">
                                    <Label.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsSelected}"
                                            TargetType="Label"
                                            Value="True">
                                            <Setter Property="TextColor" Value="{DynamicResource OnContrast}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>

                <!--  Haptics  -->
                <Border Margin="0,8,0,0" Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Style="{StaticResource CardTitle}" Text="Haptics" />
                            <Label Style="{StaticResource BodySmall}" Text="A little buzz when points land" />
                        </VerticalStackLayout>
                        <Switch
                            Grid.Column="1"
                            IsToggled="{Binding IsHapticsEnabled}"
                            OnColor="{DynamicResource Brand}"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
