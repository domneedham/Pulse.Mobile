<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Pulse.Views.SubPageHeader"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:Pulse.Resources"
    x:Name="Root">

    <!--  Shared header for pushed sub-pages: back chevron on its own row, the title (+ optional
          subtitle) stacked below it. Back and title are never inline. An optional trailing text
          action sits on the back-button row, right-aligned.  -->
    <Grid Margin="0,4,0,12" RowDefinitions="Auto,Auto" RowSpacing="8">

        <!--  Row 0: back button (left) + optional trailing action (right)  -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
            <Button
                Grid.Column="0"
                Clicked="OnBackTapped"
                Style="{StaticResource IconButton}"
                Text="{x:Static resources:MdiIcons.ChevronLeft}"
                VerticalOptions="Center" />

            <!--  Optional trailing text action (e.g. "Edit", "Mark all read").  -->
            <Button
                Grid.Column="2"
                Padding="0"
                Clicked="OnActionTapped"
                FontSize="15"
                HeightRequest="44"
                IsVisible="{Binding ActionText, Source={x:Reference Root}, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                Style="{StaticResource GhostButton}"
                Text="{Binding ActionText, Source={x:Reference Root}}"
                TextColor="{DynamicResource Brand}"
                VerticalOptions="Center" />
        </Grid>

        <!--  Row 1: title + optional subtitle, below the back button  -->
        <VerticalStackLayout Grid.Row="1" Spacing="1">
            <Label
                LineBreakMode="TailTruncation"
                MaxLines="1"
                Style="{StaticResource PageTitle}"
                Text="{Binding Title, Source={x:Reference Root}}" />
            <Label
                IsVisible="{Binding Subtitle, Source={x:Reference Root}, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                Style="{StaticResource SectionLabel}"
                Text="{Binding Subtitle, Source={x:Reference Root}}"
                TextColor="{DynamicResource InkMid}" />
        </VerticalStackLayout>

    </Grid>

</ContentView>
