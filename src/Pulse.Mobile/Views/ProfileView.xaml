<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.ProfileView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:ProfileViewModel"
    Title="Profile">

    <!--  SafeAreaEdges None on the root Grid: without it, the Grid's own safe-area inset breaks the
          large-title-to-small-title collapse animation on scroll (confirmed via
          https://github.com/dotnet/maui/issues/33037#issuecomment-3657086914) — the title just
          vanishes instead of shrinking, the same fix already applied to PulseDetailView.  -->
    <Grid SafeAreaEdges="None">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,32" Spacing="20">

            <!--  Identity card  -->
            <Border Padding="18" Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <controls:AvatarView
                        Grid.Column="0"
                        AvatarUrl="{Binding AvatarUrl}"
                        DisplayName="{Binding DisplayName}"
                        Size="56" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label
                            FontFamily="SansBold"
                            FontSize="18"
                            Text="{Binding DisplayName}"
                            TextColor="{DynamicResource Ink}" />
                        <Label Style="{StaticResource Caption}" Text="{Binding Username}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  Partner / connection  -->
            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource SectionLabel}" Text="YOUR PULSE" />
                <Border Padding="16" Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                        <Border
                            Grid.Column="0"
                            Background="{DynamicResource BrandSoft}"
                            HeightRequest="44"
                            StrokeShape="RoundRectangle 22"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            WidthRequest="44">
                            <Label
                                FontFamily="mdi"
                                FontSize="22"
                                HorizontalOptions="Center"
                                Text="{x:Static resources:MdiIcons.HeartPulse}"
                                TextColor="{DynamicResource Brand}"
                                VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label
                                FontFamily="SansBold"
                                FontSize="16"
                                Text="{Binding PartnerName}"
                                TextColor="{DynamicResource Ink}" />
                            <Label Style="{StaticResource Caption}" Text="{Binding ConnectionStatusText}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!--  Settings links  -->
            <VerticalStackLayout Spacing="10">
                <Label Style="{StaticResource SectionLabel}" Text="SETTINGS" />
                <Border Padding="4" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditProfileCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Style="{StaticResource BodyMedium}" Text="Edit profile" VerticalOptions="Center" />
                            <controls:AppIcon Grid.Column="1" Color="{DynamicResource InkLight}" Icon="ChevronRight" Size="20" />
                        </Grid>
                        <BoxView Style="{StaticResource RowDivider}" />

                        <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AppSettingsCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Style="{StaticResource BodyMedium}" Text="App settings" VerticalOptions="Center" />
                            <controls:AppIcon Grid.Column="1" Color="{DynamicResource InkLight}" Icon="ChevronRight" Size="20" />
                        </Grid>
                        <BoxView Style="{StaticResource RowDivider}" />

                        <Grid Padding="14,14" ColumnDefinitions="*,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding HelpSupportCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Style="{StaticResource BodyMedium}" Text="Help &amp; support" VerticalOptions="Center" />
                            <controls:AppIcon Grid.Column="1" Color="{DynamicResource InkLight}" Icon="ChevronRight" Size="20" />
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!--  Danger / session actions  -->
            <VerticalStackLayout Margin="0,8,0,0" Spacing="10">
                <Button
                    Command="{Binding DisconnectCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Text="Disconnect" />
                <Button
                    Command="{Binding SignOutCommand}"
                    Style="{StaticResource GhostButton}"
                    Text="Sign out"
                    TextColor="{DynamicResource InkMid}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

    <controls:ComposeButton />
    </Grid>

</ContentPage>
