<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.ManagePacksView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:ManagePacksViewModel"
    Title="Moment packs"
    Shell.TabBarIsVisible="False">

    <Grid Padding="20,16,20,20" RowDefinitions="Auto,*">

        <!--  Upgrade banner (non-Pro only)  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,12"
            Padding="14"
            Background="{DynamicResource AccentSoft}"
            IsVisible="{Binding ShowUpgradeBanner}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 16"
            StrokeThickness="0">
            <HorizontalStackLayout Spacing="10">
                <controls:AppIcon Color="{DynamicResource Accent}" Icon="Sparkles" Size="22" VerticalOptions="Center" />
                <Label
                    HorizontalOptions="FillAndExpand"
                    Style="{StaticResource BodySmall}"
                    Text="Core is always on. Unlock premium packs with Pulse Pro — tap a locked pack to upgrade."
                    VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Packs}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:PackVm">
                    <Grid Padding="0,8">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ManagePacksViewModel}}, Path=ToggleCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Border Padding="14" Style="{StaticResource Card}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" Background="{DynamicResource BrandSoft}" HeightRequest="44" StrokeShape="RoundRectangle 14" StrokeThickness="0" VerticalOptions="Center" WidthRequest="44">
                                    <Label FontSize="22" HorizontalOptions="Center" Text="{Binding Emoji}" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label FontFamily="SansBold" FontSize="16" Text="{Binding Title}" TextColor="{DynamicResource Ink}" />
                                    <Label Style="{StaticResource Caption}" Text="{Binding Subtitle}" />
                                </VerticalStackLayout>

                                <!--  Lock badge for locked Pro packs  -->
                                <controls:AppIcon Grid.Column="2" Color="{DynamicResource InkLight}" Icon="Lock" IsVisible="{Binding Locked}" Size="20" VerticalOptions="Center" />

                                <!--  Toggle for unlocked packs (visual only — the row tap drives selection
                                      through ToggleCommand; Core stays on and disabled).  -->
                                <Switch
                                    Grid.Column="2"
                                    InputTransparent="True"
                                    IsEnabled="{Binding CanToggle}"
                                    IsToggled="{Binding Selected}"
                                    IsVisible="{Binding Locked, Converter={StaticResource InvertedBoolConverter}}"
                                    OnColor="{DynamicResource Brand}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
