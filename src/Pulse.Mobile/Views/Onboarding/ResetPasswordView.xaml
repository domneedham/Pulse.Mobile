<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.Onboarding.ResetPasswordView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:ResetPasswordViewModel"
    Title="Reset password"
    Shell.TabBarIsVisible="False">

    <Grid Padding="16,8,16,32" RowDefinitions="*,Auto">

        <VerticalStackLayout
            Grid.Row="0"
            Spacing="12"
            VerticalOptions="Center">
            <Label Style="{StaticResource PageTitle}" Text="Reset your password" />
            <Label
                Margin="0,0,0,16"
                Style="{StaticResource BodyMedium}"
                Text="Enter your email and we'll send you a link to reset it." />

            <Border Style="{StaticResource InputField}">
                <Entry
                    Keyboard="Email"
                    Placeholder="Email"
                    Text="{Binding Email}" />
            </Border>
        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Command="{Binding SendCommand}"
            Text="Send reset link" />

    </Grid>

</ContentPage>
