<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.Onboarding.SignInView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pulse.Views"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:SignInViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid Padding="16,8,16,32">

        <ScrollView>
            <VerticalStackLayout Margin="0,48,0,0" Spacing="12">
            <Label Style="{StaticResource PageTitle}" Text="Welcome back" />
            <Label
                Margin="0,0,0,16"
                Style="{StaticResource BodyMedium}"
                Text="Sign in to pick up the race where you left it." />

            <Border Style="{StaticResource InputField}">
                <Entry
                    Keyboard="Email"
                    Placeholder="Email"
                    Text="{Binding Email}" />
            </Border>

            <Border Style="{StaticResource InputField}">
                <Entry
                    IsPassword="True"
                    Placeholder="Password"
                    Text="{Binding Password}" />
            </Border>

            <Button
                Command="{Binding ForgotPasswordCommand}"
                HorizontalOptions="End"
                Padding="0"
                FontSize="14"
                HeightRequest="36"
                Style="{StaticResource GhostButton}"
                Text="Forgot password?"
                TextColor="{DynamicResource Brand}" />

            <Grid Margin="0,4,0,0">
                <Button
                    Command="{Binding SignInCommand}"
                    IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Text="Sign in" />
                <ActivityIndicator
                    HeightRequest="54"
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}" />
            </Grid>

            <!--  Social sign-in (coming soon)  -->
            <views:SocialAuthButtons Margin="0,8,0,0" />

            <!--  Switch to sign-up  -->
            <Button
                Command="{Binding SignUpCommand}"
                Style="{StaticResource GhostButton}"
                Text="Don't have an account? Sign up"
                TextColor="{DynamicResource InkMid}" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
