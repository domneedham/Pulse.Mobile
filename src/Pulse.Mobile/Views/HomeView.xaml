<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pulse.Views.HomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Pulse.UI.Controls"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:HomeViewModel"
    Title="Home">

    <!--  SafeAreaEdges None on the root Grid: without it, the Grid's own safe-area inset breaks the
          large-title-to-small-title collapse animation on scroll (confirmed via
          https://github.com/dotnet/maui/issues/33037#issuecomment-3657086914) — the title just
          vanishes instead of shrinking, the same fix already applied to PulseDetailView.  -->
    <Grid SafeAreaEdges="None">
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,28" Spacing="26">

                <!--  Today's Moment — the card itself (title, thumbnails, avatar checkmarks) already
                      tells the story, so no status subtitle repeating "waiting for partner" here.  -->
                <VerticalStackLayout IsVisible="{Binding HasMoment}" Spacing="10">
                    <HorizontalStackLayout Spacing="6">
                        <Label FontFamily="SansExtraBold" FontSize="20" Text="Today's Moment" TextColor="{DynamicResource Ink}" />
                        <Label FontSize="18" Text="✨" />
                    </HorizontalStackLayout>

                    <Border Padding="18" Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMomentCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="16">

                            <!--  Category pill  -->
                            <Border
                                Padding="10,5"
                                Background="{DynamicResource BrandSoft}"
                                HorizontalOptions="Start"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="0">
                                <HorizontalStackLayout Spacing="6">
                                    <controls:AppIcon Color="{DynamicResource Brand}" Icon="{Binding TodaysMoment.Icon}" Size="14" VerticalOptions="Center" />
                                    <Label FontFamily="SansSemiBold" FontSize="12" Text="{Binding TodaysMoment.CategoryLabel}" TextColor="{DynamicResource Brand}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!--  Title + prompt + optional thumbnail  -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                                    <Label FontFamily="SansExtraBold" FontSize="26" Text="{Binding TodaysMoment.Title}" TextColor="{DynamicResource Ink}" />
                                    <Label Style="{StaticResource BodyMedium}" Text="{Binding TodaysMoment.Prompt}" />
                                </VerticalStackLayout>
                                <!--  Thumbnail slot: partner's and mine always show, overlapping into a
                                      scattered-Polaroid stack — each tile is nudged a few degrees
                                      off-axis in opposite directions, so the back tile's corners peek out
                                      from behind the front one instead of being fully hidden behind
                                      identical square edges. Either tile shows its photo/drawing, or (via
                                      MomentThumbnailView) that person's initials on their colour if they
                                      haven't answered with one yet — always both slots, so it reads as
                                      "here's what each of you shared" rather than appearing/disappearing
                                      based on who happened to add a photo.  -->
                                <Grid
                                    Grid.Column="1"
                                    HeightRequest="88"
                                    VerticalOptions="Center"
                                    WidthRequest="100">
                                    <controls:MomentThumbnailView
                                        HeightRequest="80"
                                        HorizontalOptions="Start"
                                        PersonName="{Binding TodaysMoment.PartnerName}"
                                        PhotoUrl="{Binding TodaysMoment.PartnerPhotoUrl}"
                                        Rotation="-12"
                                        StrokeData="{Binding TodaysMoment.PartnerStrokeData}"
                                        WidthRequest="64"
                                        ZIndex="0" />
                                    <controls:MomentThumbnailView
                                        HeightRequest="80"
                                        HorizontalOptions="End"
                                        PersonName="{Binding TodaysMoment.MyName}"
                                        PhotoUrl="{Binding TodaysMoment.MyPhotoUrl}"
                                        Rotation="12"
                                        StrokeData="{Binding TodaysMoment.MyStrokeData}"
                                        WidthRequest="64"
                                        ZIndex="1" />
                                </Grid>
                            </Grid>

                            <!--  Two-avatar progress row  -->
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Grid>
                                        <controls:AvatarView AvatarUrl="{Binding TodaysMoment.MyAvatarUrl}" DisplayName="{Binding TodaysMoment.MyName}" Size="38" />
                                        <Border
                                            Background="{DynamicResource Brand}"
                                            HeightRequest="16"
                                            HorizontalOptions="End"
                                            IsVisible="{Binding TodaysMoment.MyDone}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            VerticalOptions="End"
                                            WidthRequest="16">
                                            <controls:AppIcon Color="White" HorizontalOptions="Center" Icon="Check" Size="10" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                    <Label FontSize="11" HorizontalOptions="Center" Style="{StaticResource Caption}" Text="{Binding TodaysMoment.MyName}" />
                                </VerticalStackLayout>

                                <BoxView Grid.Column="1" Background="{DynamicResource Stroke}" HeightRequest="2" Margin="10,0" VerticalOptions="Center" />

                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Grid>
                                        <controls:AvatarView AvatarUrl="{Binding TodaysMoment.PartnerAvatarUrl}" DisplayName="{Binding TodaysMoment.PartnerName}" Size="38" />
                                        <Border
                                            Background="{DynamicResource Brand}"
                                            HeightRequest="16"
                                            HorizontalOptions="End"
                                            IsVisible="{Binding TodaysMoment.PartnerDone}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 8"
                                            VerticalOptions="End"
                                            WidthRequest="16">
                                            <controls:AppIcon Color="White" HorizontalOptions="Center" Icon="Check" Size="10" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                    <Label FontSize="11" HorizontalOptions="Center" Style="{StaticResource Caption}" Text="{Binding TodaysMoment.PartnerName}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!--  Action: only shown while there's something to do. Once you've answered
                                  (waiting on your partner, or both done), the card itself already tells
                                  the story — no status pill nagging about a state you can't act on.  -->
                            <Button
                                Command="{Binding OpenMomentCommand}"
                                IsVisible="{Binding TodaysMoment.CanRespond}"
                                Text="Start Moment" />

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!--  Latest Signal  -->
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" FontFamily="SansExtraBold" FontSize="20" Text="Latest Signal" TextColor="{DynamicResource Ink}" />
                        <Label Grid.Column="1" FontFamily="SansSemiBold" FontSize="14" Text="See all" TextColor="{DynamicResource Brand}" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeeAllCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!--  Latest pulse row  -->
                    <Border Padding="14" IsVisible="{Binding HasLatest}" Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenLatestCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" Background="{DynamicResource BrandSoft}" HeightRequest="44" StrokeShape="RoundRectangle 14" StrokeThickness="0" VerticalOptions="Center" WidthRequest="44">
                                <controls:AppIcon Color="{DynamicResource Brand}" Icon="{Binding Latest.Icon}" Size="21" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label FontFamily="SansBold" FontSize="16" Text="{Binding Latest.Text}" TextColor="{DynamicResource Ink}" />
                                <Label Style="{StaticResource Caption}" Text="{Binding Latest.When}" />
                            </VerticalStackLayout>
                            <controls:AppIcon Grid.Column="2" Color="{DynamicResource InkLight}" Icon="ChevronRight" Size="20" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!--  Empty state  -->
                    <Border Padding="20,28" IsVisible="{Binding ShowEmptyState}" Style="{StaticResource Card}">
                        <VerticalStackLayout Spacing="12">
                            <Border
                                Background="{DynamicResource AccentSoft}"
                                HeightRequest="72"
                                HorizontalOptions="Center"
                                StrokeShape="RoundRectangle 36"
                                StrokeThickness="0"
                                WidthRequest="72">
                                <controls:AppIcon Color="{DynamicResource Accent}" Icon="HeartOutline" Size="34" />
                            </Border>
                            <Label FontFamily="SansBold" FontSize="18" HorizontalOptions="Center" Text="No signals yet" TextColor="{DynamicResource Ink}" />
                            <Label HorizontalOptions="Center" Style="{StaticResource BodySmall}" Text="Send the first signal." />
                            <Button
                                Margin="0,4,0,0"
                                Command="{Binding OpenComposeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="Send a signal" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

    <controls:ComposeButton />
    </Grid>

</ContentPage>
