<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Pulse.UI.Controls.SendPulseSheetView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:Pulse.Resources"
    xmlns:vm="clr-namespace:Pulse.ViewModels"
    x:DataType="vm:SendPulseViewModel">

    <!--  Full-height sheet: favourites first, then more options, then a custom field.  -->
    <Border
        Background="{DynamicResource Surface}"
        Stroke="Transparent"
        StrokeShape="RoundRectangle 24,24,0,0"
        VerticalOptions="Fill">
        <Border.Shadow>
            <Shadow Brush="{DynamicResource Ink}" Opacity="0.12" Radius="16" Offset="0,-4" />
        </Border.Shadow>

        <Grid Padding="16,8,16,24" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="6" SafeAreaEdges="None">

            <BoxView Grid.Row="0" Margin="0,4,0,4" Style="{StaticResource DragHandle}" />

            <!--  Title + (back on note step) + close  -->
            <Grid Grid.Row="1" Margin="0,4,0,8" ColumnDefinitions="Auto,*,Auto">
                <Button
                    Grid.Column="0"
                    Command="{Binding BackToPickerCommand}"
                    IsVisible="{Binding IsNoteStep}"
                    Style="{StaticResource IconButtonGhost}"
                    Text="{x:Static resources:MdiIcons.ChevronLeft}" />
                <Label Grid.Column="1" Style="{StaticResource PageTitle}" Text="{Binding Title}" VerticalOptions="Center" />
                <Button
                    Grid.Column="2"
                    Command="{Binding CloseCommand}"
                    StyleId="glass"
                    Style="{StaticResource IconButtonGhost}"
                    Text="{x:Static resources:MdiIcons.Close}" />
            </Grid>

            <!--  STEP 1: Favourites + more options (picker)  -->
            <ScrollView Grid.Row="2" IsVisible="{Binding ShowPicker}">
                <VerticalStackLayout Spacing="6">

                    <Label Style="{StaticResource SectionLabel}" Text="YOUR FAVOURITES" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Favorites}" Spacing="2">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PhraseRow">
                                <Grid Padding="8,12" Background="{DynamicResource BrandSoft}" ColumnDefinitions="Auto,*">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SendPulseViewModel}}, Path=PickCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" FontSize="22" Text="{Binding Emoji}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Margin="12,0,0,0" FontFamily="SansMedium" FontSize="17" Text="{Binding Text}" TextColor="{DynamicResource Ink}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Label
                        Margin="0,12,0,0"
                        IsVisible="{Binding HasMoreOptions}"
                        Style="{StaticResource SectionLabel}"
                        Text="MORE OPTIONS" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding MoreOptions}" Spacing="2">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PhraseRow">
                                <Grid Padding="8,12" ColumnDefinitions="Auto,*">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SendPulseViewModel}}, Path=PickCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Grid.Column="0" FontSize="22" Text="{Binding Emoji}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Margin="12,0,0,0" FontFamily="SansMedium" FontSize="17" Text="{Binding Text}" TextColor="{DynamicResource Ink}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <!--  STEP 2: optional note then send  -->
            <ScrollView Grid.Row="2" IsVisible="{Binding IsNoteStep}">
                <VerticalStackLayout Spacing="14">
                    <!--  Chosen phrase preview  -->
                    <Border Padding="14" Background="{DynamicResource BrandSoft}" Stroke="Transparent" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                        <HorizontalStackLayout Spacing="12">
                            <Label FontSize="26" Text="{Binding SelectedEmoji}" VerticalOptions="Center" />
                            <Label FontFamily="SansBold" FontSize="18" Text="{Binding SelectedText}" TextColor="{DynamicResource Ink}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Label Style="{StaticResource SectionLabel}" Text="ADD A NOTE (OPTIONAL)" />
                    <Border Padding="12,4" Style="{StaticResource InputField}">
                        <Editor
                            AutoSize="TextChanges"
                            HeightRequest="90"
                            MaxLength="80"
                            Placeholder="A little something to go with it…"
                            Text="{Binding Note}" />
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!--  Footer: picker = custom entry ("Next"); note step = Send  -->
            <VerticalStackLayout Grid.Row="3" Margin="0,8,0,0" Spacing="8">
                <Border IsVisible="{Binding ShowPicker}" Style="{StaticResource InputField}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            Grid.Column="0"
                            Placeholder="Or write your own…"
                            ReturnCommand="{Binding ContinueWithCustomCommand}"
                            ReturnType="Next"
                            Text="{Binding CustomText}" />
                        <Button
                            Grid.Column="1"
                            Padding="14,0"
                            Command="{Binding ContinueWithCustomCommand}"
                            HeightRequest="40"
                            Text="Next"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Button
                    Command="{Binding SendCommand}"
                    IsVisible="{Binding IsNoteStep}"
                    Text="Send" />
            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentView>
